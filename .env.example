# ============================================================
# 实习能量站 - 环境变量配置
# ============================================================
# 使用方式：复制此文件为 .env，然后填入你的 API Key
# cp .env.example .env
# ============================================================

# Flask 密钥（用于 session 加密，生产环境请改为随机字符串）
SECRET_KEY=intern-growth-os-secret-key-2026

# AI 模式（可选值：mock | deepseek | openai | claude）
AI_MODE=deepseek

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API 配置（可选）
OPENAI_API_KEY=

# Claude API 配置（可选）
CLAUDE_API_KEY=

# 服务器端口（可选，默认 5000）
PORT=5000
